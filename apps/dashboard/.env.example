# Dashboard env (Next.js). Copy thành .env.local nếu backend KHÔNG ở localhost:8000.
# (.env.local bị gitignore.) Mặc định trong code đã trỏ localhost:8000.
# Lưu ý: biến NEXT_PUBLIC_* được "bake" lúc build — đổi xong phải build lại.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/chat
