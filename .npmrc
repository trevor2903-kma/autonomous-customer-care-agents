# node-linker=hoisted: flat node_modules cho monorepo pnpm (Next.js + shared-types chạy tốt với layout này).
# Giữ nguyên để tránh churn cài đặt lại; không đổi phiên bản React đã pin (18.2.0).
node-linker=hoisted
# Cho phép script build của dependency (esbuild, sharp...) chạy khi cài.
enable-pre-post-scripts=true
