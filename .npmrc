# node-linker=hoisted: flat node_modules — Expo/React Native (Metro) và Next.js đều ưa layout này
# trong monorepo pnpm; tránh lỗi resolve native module (@babel/runtime, RN internals...).
# Điều kiện: mọi package dùng CÙNG một bản React (ở đây 18.2.0 theo Expo SDK 51) -> tránh "duplicate React".
node-linker=hoisted
# Cho phép script build của dependency (esbuild, sharp...) chạy khi cài.
enable-pre-post-scripts=true
