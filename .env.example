# =============================================================================
# .env.example — autonomous-customer-support-system (scaffold)
# Copy thành `.env` rồi điền secret. `.env` bị gitignore — CHỈ commit file này.
# Nguồn chân lý cấu hình nghiệp vụ: PRD.md. Quy ước: CLAUDE.md.
# =============================================================================
#
# ┌─ CHECKLIST TÀI KHOẢN MANAGED (PRD §6 / plan §5) ──────────────────────────┐
# │ Dịch vụ        Đăng ký                       Cần lấy                       │
# │ Neon           https://neon.tech             Postgres connection string    │
# │ Upstash Redis  https://upstash.com           rediss:// URL (TLS) + REST    │
# │ Qdrant Cloud   https://cloud.qdrant.io        Cluster URL + API key         │
# │ Langfuse (opt) https://cloud.langfuse.com      Public + Secret key (sau)     │
# │ LLM (opt, sau) OpenAI/Anthropic/Gemini         API key (ENABLE_LLM=false)    │
# └────────────────────────────────────────────────────────────────────────────┘
#
# Chưa có tài khoản managed? Dùng local:  `make local-infra-up`  rồi mở phần LOCAL bên dưới.

# ─── App ─────────────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
# ENABLE_LLM chỉ gate BƯỚC CHỌN INTENT bằng LLM (bật: LLM chọn intent + trích entities; tắt:
# similarity top-1 từ Qdrant). Embeddings cho RAG KHÔNG bị gate cờ này — xem mục LLM provider.
ENABLE_LLM=false
# CORS cho dashboard/cổng chat khách (nhiều origin: phân tách bằng dấu phẩy)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Ngưỡng cấu hình được (PRD §18 NFR-10; tinh chỉnh ở Chương 4) ─────────────
CONFIDENCE_THRESHOLD=0.6
AUTO_RESOLVE_MINUTES=30
CONTEXT_WINDOW_MESSAGES=10
# Intent Classifier (PRD §7.1): 2 ứng viên RAG đầu chênh score < margin -> cờ ambiguous_intent.
INTENT_AMBIGUOUS_MARGIN=0.05

# ─── Auth / Admin (slice 11 — JWT + RBAC) ────────────────────────────────────
# JWT_SECRET: BẮT BUỘC (P1). Sinh chuỗi ngẫu nhiên mạnh:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# Hạn token đăng nhập (phút). Mặc định 10080 = 7 ngày.
JWT_EXPIRE_MINUTES=10080
# Admin seed — scripts/seed_admin.py đọc các biến này (KHÔNG commit giá trị thật vào .env.example).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Quản trị viên

# ─── Postgres (Neon) ─────────────────────────────────────────────────────────
# Dùng driver async: tiền tố `postgresql+asyncpg://`.
# QUAN TRỌNG (CLAUDE.md): KHÔNG để `?sslmode=` — asyncpg không hiểu. SSL bật qua
# connect_args={"ssl": True} trong code. Bỏ mọi query param khỏi URL.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME
# Neon = true. Local docker (không TLS) = false.
DATABASE_SSL=true

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
# Upstash yêu cầu TLS → dùng scheme `rediss://`. Session ngắn hạn + (TODO) pub/sub.
REDIS_URL=rediss://default:TOKEN@HOST:6379
# REST (tùy chọn — một số tiện ích Upstash dùng REST thay vì giao thức redis)
UPSTASH_REDIS_REST_URL=https://HOST.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── Qdrant Cloud (Vector DB cho RAG) ────────────────────────────────────────
QDRANT_URL=https://YOUR-CLUSTER.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge

# ─── Langfuse (observability — phase sau, optional) ──────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ─── LLM provider (RAG intent classification) ────────────────────────────────
# Lát cắt RAG-intent: chỉ hỗ trợ OpenAI. LLM_API_KEY cần cho CẢ embeddings (RAG) LẪN bước chọn intent.
# Embeddings luôn cần (độc lập ENABLE_LLM); LLM_MODEL chỉ dùng khi ENABLE_LLM=true.
LLM_PROVIDER=openai          # openai (lát cắt này chỉ hỗ trợ openai)
LLM_API_KEY=                 # OpenAI API key (embeddings + bước chọn intent)
LLM_MODEL=gpt-4o-mini        # model chat cho bước chọn intent (khi ENABLE_LLM=true)
EMBEDDING_MODEL=text-embedding-3-small

# ─── Frontend (Next.js dashboard) ────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/chat

# =============================================================================
# LOCAL (docker-compose.local.yml) — bỏ comment & thay phần managed ở trên nếu
# chạy hạ tầng local. (`make local-infra-up`)
# =============================================================================
# DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/csm
# DATABASE_SSL=false
# REDIS_URL=redis://localhost:6379
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
